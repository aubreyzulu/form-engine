{
  "name": "openownership-form-builder",
  "version": "0.1.0",
  "private": true,
  "description": "Dynamic Form Builder Engine — OpenOwnership full-stack assessment (Assignment A)",
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "build:api": "pnpm --filter @formbuilder/shared build && pnpm --filter api prisma:generate && pnpm --filter api build",
    "build:web": "pnpm --filter @formbuilder/shared build && pnpm --filter web build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "start:api": "pnpm --filter api start:prod",
    "start:web": "pnpm --filter web start",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}

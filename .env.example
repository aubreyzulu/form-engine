# Local Postgres defaults used by docker-compose.yml.
POSTGRES_USER=app
POSTGRES_DB=form-engine
POSTGRES_PORT=5432
POSTGRES_HOST_AUTH_METHOD=trust

# API / Prisma inside docker-compose. Use apps/api/.env for host-run API commands.
DATABASE_URL="postgresql://app@postgres:5432/form-engine"
PORT=4000
CORS_ORIGINS="http://localhost:3000"

# Web.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
